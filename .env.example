ENVIRONMENT=development
SERVICE_NAME=neuraclinic-api-gateway
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

AUTH_GRPC_ADDR=neuraclinic-auth:8000
AUTH_GRPC_TLS_ENABLED=true
AUTH_GRPC_CA_CERT_PATH=/app/auth-certs/local_ca_cert.pem
AUTH_GRPC_INSECURE_SKIP_VERIFY=false

USERS_GRPC_ADDR=neuraclinic-users:8000
USERS_GRPC_TLS_ENABLED=true
USERS_GRPC_CA_CERT_PATH=/app/users-certs/local_ca_cert.pem
USERS_GRPC_INSECURE_SKIP_VERIFY=false

RECORDS_GRPC_ADDR=neuraclinic-records:8000
RECORDS_GRPC_TLS_ENABLED=true
RECORDS_GRPC_CA_CERT_PATH=/app/records-certs/local_ca_cert.pem
RECORDS_GRPC_INSECURE_SKIP_VERIFY=false

LOCATION_GRPC_ADDR=neuraclinic-location:8000
LOCATION_GRPC_TLS_ENABLED=true
LOCATION_GRPC_CA_CERT_PATH=/app/location-certs/local_ca_cert.pem
LOCATION_GRPC_INSECURE_SKIP_VERIFY=false

FILE_MANAGEMENT_GRPC_ADDR=neuraclinic-file-management:8000
FILE_MANAGEMENT_GRPC_TLS_ENABLED=true
FILE_MANAGEMENT_GRPC_CA_CERT_PATH=/app/file-management-certs/local_ca_cert.pem
FILE_MANAGEMENT_GRPC_INSECURE_SKIP_VERIFY=false

INTERNAL_SERVICE_TOKEN=local-internal-service-token

COOKIE_DOMAIN=
COOKIE_SECURE=false
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
